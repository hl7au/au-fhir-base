<?xml version="1.0" encoding="utf-8"?>
<StructureDefinition xmlns="http://hl7.org/fhir">
  <id value="au-endpoint" />
  <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-fmm">
    <valueInteger value="0"/> 
  </extension>
  <url value="http://hl7.org.au/fhir/StructureDefinition/au-endpoint" />
  <name value="AUBaseEndpoint" />
  <title value="AU Base Endpoint" />
  <status value="active" />
  <description value="This profile defines an endpoint structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." />
  <kind value="resource" />
  <abstract value="false" />
  <type value="Endpoint" />
  <baseDefinition value="http://hl7.org/fhir/StructureDefinition/Endpoint|4.0.1" />
  <derivation value="constraint" />
  <differential>
    <element id="Endpoint">
      <path value="Endpoint" />
      <short value="An endpoint in an Australian healthcare context" />
    </element>
    <element id="Endpoint.extension:au-receivingfacility">
      <path value="Endpoint.extension" />
      <sliceName value="au-receivingfacility" />
      <comment value="Use the AU Receiving Facility extension to indicate the receiving facility details."/>
      <min value="0" />
      <max value="1" />
      <type>
        <code value="Extension" />
        <profile value="http://hl7.org.au/fhir/StructureDefinition/au-receivingfacility" />
      </type>
    </element>
    <element id="Endpoint.extension:au-receivingapplication">
      <path value="Endpoint.extension" />
      <sliceName value="au-receivingapplication" />
      <comment value="Use the AU Receiving Application extension to indicate the receiving application details."/>
      <min value="0" />
      <max value="1" />
      <type>
        <code value="Extension" />
        <profile value="http://hl7.org.au/fhir/StructureDefinition/au-receivingapplication" />
      </type>
    </element>
    <element id="Endpoint.extension:au-environmentType">
      <path value="Endpoint.extension" />
      <sliceName value="au-environmentType" />
      <comment value="The type of environment(s) exposed at this endpoint"/>
      <min value="0" />
      <max value="*" />
      <type>
        <code value="Extension" />
        <profile value="http://hl7.org.au/fhir/StructureDefinition/au-environmenttype" />
      </type>
    </element>
    <element id="Endpoint.extension:au-implementationGuideSupported">
      <path value="Endpoint.extension" />
      <sliceName value="au-implementationGuideSupported" />
      <comment value="Indicates an Implementation Guide that this endpoint supports."/>
      <min value="0" />
      <max value="*" />
      <type>
        <code value="Extension" />
        <profile value="http://hl7.org.au/fhir/StructureDefinition/au-implementation-guide" />
      </type>
    </element>
    <element id="Endpoint.extension:encryption-certificate-pem-x509">
      <path value="Endpoint.extension" />
      <sliceName value="encryption-certificate-pem-x509" />
      <comment value="X.509 PEM certificate for endpoint encryption."/>
      <min value="0" />
      <max value="1" />
      <type>
        <code value="Extension" />
        <profile value="http://hl7.org.au/fhir/StructureDefinition/encryption-certificate-pem-x509" />
      </type>
    </element>
    <element id="Endpoint.connectionType">
      <path value="Endpoint.connectionType" />
      <binding>
        <strength value="preferred" />
        <valueSet value="http://hl7.org.au/fhir/ValueSet/au-service-interfaces" />
      </binding>
    </element>
    <element id="Endpoint.payloadType">
      <path value="Endpoint.payloadType" />
      <binding>
        <strength value="preferred" />
        <valueSet value="http://hl7.org.au/fhir/ValueSet/au-endpoint-payload-type" />
      </binding>
    </element>
  </differential>
</StructureDefinition>
