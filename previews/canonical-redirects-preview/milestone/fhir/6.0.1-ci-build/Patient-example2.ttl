       fhir:end [ fhir:v "2019-05"^^xsd:gYearMonth ]
     ]
  ] ) ; # 
  fhir:name ( [
     fhir:family [ fhir:v "Grant" ] ;
     fhir:given ( [ fhir:v "Sally" ] )
  ] ) ; # 
  fhir:telecom ( [
     fhir:system [ fhir:v "email" ] ;
     fhir:value [ fhir:v "sgrant@amail.example.com" ]
  ] ) ; # 
