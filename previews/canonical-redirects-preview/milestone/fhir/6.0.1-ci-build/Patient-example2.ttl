         fhir:display [ fhir:v "Patient's Medicare Number" ]
       ] ) ;
       fhir:text [ fhir:v "Medicare Number" ]
     ] ;
     fhir:system [ fhir:v "http://ns.electronichealth.net.au/id/medicare-number"^^xsd:anyURI ] ;
     fhir:value [ fhir:v "1234567892" ] ;
