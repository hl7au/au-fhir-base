  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Address" ] ;
       fhir:path [ fhir:v "Address" ] ;
       fhir:short [ fhir:v "An address in Australia for use within an Australian healthcare context" ] ;
       fhir:definition [ fhir:v "An Australian address expressed using postal conventions (as opposed to GPS or other location definition formats)." ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "inv-add-0" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "The address shall at least have text or a line" ] ;
         fhir:expression [ fhir:v "text.exists() or line.exists()" ] ;
         fhir:source [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address>
         ]
       ] [
         fhir:key [ fhir:v "inv-add-1" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If asserting no fixed address, the type shall be 'physical'" ] ;
         fhir:expression [ fhir:v "extension('http://hl7.org.au/fhir/StructureDefinition/no-fixed-address').exists() implies type='physical'" ] ;
         fhir:source [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address>
         ]
       ] [
         fhir:key [ fhir:v "inv-add-2" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If asserting no fixed address, the address text shall begin with 'NO FIXED ADDRESS'" ] ;
         fhir:expression [ fhir:v "extension('http://hl7.org.au/fhir/StructureDefinition/no-fixed-address').exists() implies text.startsWith('NO FIXED ADDRESS')" ] ;
         fhir:source [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "Address.extension" ] ;
       fhir:path [ fhir:v "Address.extension" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "url" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ]
     ] [
       fhir:id [ fhir:v "Address.extension:identifier" ] ;
       fhir:path [ fhir:v "Address.extension" ] ;
       fhir:sliceName [ fhir:v "identifier" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Extension"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/address-identifier"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/address-identifier>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Address.extension:identifier.value[x]" ] ;
       fhir:path [ fhir:v "Address.extension.value[x]" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Identifier"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Identifier"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Identifier>
         ] [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-deliverypointidentifier"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-deliverypointidentifier>
         ] [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-gnafidentifier"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-gnafidentifier>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Address.extension:noFixedAddress" ] ;
       fhir:path [ fhir:v "Address.extension" ] ;
       fhir:sliceName [ fhir:v "noFixedAddress" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Extension"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/no-fixed-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/no-fixed-address>
         ] )
       ] ) ;
       fhir:condition ( [ fhir:v "inv-add-1" ] [ fhir:v "inv-add-2" ] )
     ] [
       fhir:id [ fhir:v "Address.type" ] ;
       fhir:path [ fhir:v "Address.type" ] ;
       fhir:condition ( [ fhir:v "inv-add-1" ] )
     ] [
       fhir:id [ fhir:v "Address.text" ] ;
       fhir:path [ fhir:v "Address.text" ] ;
       fhir:condition ( [ fhir:v "inv-add-0" ] [ fhir:v "inv-add-2" ] )
     ] [
       fhir:id [ fhir:v "Address.line" ] ;
       fhir:path [ fhir:v "Address.line" ] ;
       fhir:condition ( [ fhir:v "inv-add-0" ] )
     ] [
       fhir:id [ fhir:v "Address.city" ] ;
       fhir:path [ fhir:v "Address.city" ] ;
       fhir:short [ fhir:v "Name of city, town or suburb" ]
     ] [
       fhir:id [ fhir:v "Address.state" ] ;
       fhir:path [ fhir:v "Address.state" ] ;
       fhir:short [ fhir:v "Australian state or territory" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://healthterminologies.gov.au/fhir/ValueSet/australian-states-territories-2"^^xsd:anyURI ;
           fhir:link <https://healthterminologies.gov.au/fhir/ValueSet/australian-states-territories-2>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Address.postalCode" ] ;
       fhir:path [ fhir:v "Address.postalCode" ] ;
       fhir:condition ( [ fhir:v "inv-add-3" ] ) ;
       fhir:constraint ( [
         fhir:key [ fhir:v "inv-add-3" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Postal code shall be 4 digits" ] ;
         fhir:expression [ fhir:v "matches('^[0-9]{4}$')" ] ;
         fhir:source [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "Address.country" ] ;
       fhir:path [ fhir:v "Address.country" ] ;
       fhir:short [ fhir:v "Australia as a 2 digit ISO 3166 code" ] ;
       fhir:definition [ fhir:v "Fixed value if present otherwise assumed to be Australia in this context." ] ;
       fhir:fixed [
         a fhir:string ;
         fhir:v "AU"
       ]
     ] )
  ] . # 

