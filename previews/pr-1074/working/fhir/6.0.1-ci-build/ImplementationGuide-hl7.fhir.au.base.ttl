     fhir:resource ( [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "SearchParameter"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/SearchParameter/encounter-discharge-disposition> ;
         fhir:reference [ fhir:v "SearchParameter/encounter-discharge-disposition" ]
       ] ;
       fhir:name [ fhir:v "EncounterDischargeDisposition" ] ;
       fhir:description [ fhir:v "This search parameter returns encounters with a discharge-disposition matching the specified code." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "SearchParameter"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/SearchParameter/indigenous-status> ;
         fhir:reference [ fhir:v "SearchParameter/indigenous-status" ]
       ] ;
       fhir:name [ fhir:v "AustralianIndigenousStatus" ] ;
       fhir:description [ fhir:v "This search parameter returns patients with an Australian Indigenous Status extension matching the specified code." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "SearchParameter"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/SearchParameter/gender-identity> ;
         fhir:reference [ fhir:v "SearchParameter/gender-identity" ]
       ] ;
       fhir:name [ fhir:v "GenderIdentity" ] ;
       fhir:description [ fhir:v "This search parameter returns resources with the Individual Gender Identity extension matching the specified code." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-condition> ;
         fhir:reference [ fhir:v "StructureDefinition/au-condition" ]
       ] ;
       fhir:name [ fhir:v "AU Base Condition" ] ;
       fhir:description [ fhir:v "This profile defines a condition structure that localises core concepts, including terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-coverage> ;
         fhir:reference [ fhir:v "StructureDefinition/au-coverage" ]
       ] ;
       fhir:name [ fhir:v "AU Base Coverage" ] ;
       fhir:description [ fhir:v "This profile defines a coverage structure that localises core concepts, including terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-norelevantfinding> ;
         fhir:reference [ fhir:v "StructureDefinition/au-norelevantfinding" ]
       ] ;
       fhir:name [ fhir:v "AU Assertion of No Relevant Finding" ] ;
       fhir:description [ fhir:v "This profile provides an observation information structure for asserting a clinical judgement that there are no items of specific interest, (e.g. no current medications or no history of vaccination), for a patient. An assertion of no relevant finding may be used in continuity of care or transfer or care related lists and composition sections." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-receivingapplication> ;
         fhir:reference [ fhir:v "StructureDefinition/au-receivingapplication" ]
       ] ;
       fhir:name [ fhir:v "HL7 V2 Receiving Application" ] ;
       fhir:description [ fhir:v "This extension applies to the Endpoint resource and is used to represent routing HL7 V2 message payload details associated with an endpoint. This content allows a sender using these endpoint details to include Receiving Application (MSH-5) information in HL7 V2 messages sent via this channel which allow correct delivery within the receiving system." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-receivingfacility> ;
         fhir:reference [ fhir:v "StructureDefinition/au-receivingfacility" ]
       ] ;
       fhir:name [ fhir:v "HL7 V2 Receiving Facility" ] ;
       fhir:description [ fhir:v "This extension applies to the Endpoint resource and is used to represent HL7 V2 receiving facility details for HL7 V2 routing purposes associated with an endpoint. This content allows a sender using these endpoint details to include Receiving Facility (MSH-6) information in HL7 V2 messages sent via this channel which allow correct delivery within the receiving system." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-assigningauthority> ;
         fhir:reference [ fhir:v "StructureDefinition/au-assigningauthority" ]
       ] ;
       fhir:name [ fhir:v "HL7 V2 Assigning Authority" ] ;
       fhir:description [ fhir:v "This extension applies to the [Identifier](http://hl7.org/fhir/datatypes.html#identifier) data type and is used to represent HL7 V2 assigning authority details for HL7 V2 identification for routing." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/encryption-certificate-pem-x509> ;
         fhir:reference [ fhir:v "StructureDefinition/encryption-certificate-pem-x509" ]
       ] ;
       fhir:name [ fhir:v "Encryption Certificate PEM X509" ] ;
       fhir:description [ fhir:v "This extension applies to the Endpoint resource and is used to support encrypted certificate content for use with an endpoint. This extension allows an endpoint entry to define a suitable certificate for use in communications on the associated channel." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/indigenous-status> ;
         fhir:reference [ fhir:v "StructureDefinition/indigenous-status" ]
       ] ;
       fhir:name [ fhir:v "Australian Indigenous Status" ] ;
       fhir:description [ fhir:v "This extension applies to the Patient, Person, and RelatedPerson resources and is used to indicate whether a person identifies as being of Aboriginal or Torres Strait Islander origin." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/dispense-number> ;
         fhir:reference [ fhir:v "StructureDefinition/dispense-number" ]
       ] ;
       fhir:name [ fhir:v "Dispense Number" ] ;
       fhir:description [ fhir:v "This extension applies to the MedicationDispense resource and is used to represent the dispense number or sequence number that has been reached for a therapeutic good prescribed with repeats." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/medication-long-term> ;
         fhir:reference [ fhir:v "StructureDefinition/medication-long-term" ]
       ] ;
       fhir:name [ fhir:v "Long Term" ] ;
       fhir:description [ fhir:v "This extension applies to the MedicationStatement resource and is used to indicate long term use of a medication." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/medication-type> ;
         fhir:reference [ fhir:v "StructureDefinition/medication-type" ]
       ] ;
       fhir:name [ fhir:v "Medication Type" ] ;
       fhir:description [ fhir:v "This extension applies to the [Coding](http://hl7.org/fhir/R4/datatypes.html#Coding) data type and is used to indicate the type of information covered by the code e.g. branded product with no strength or form. This is useful when there are multiple codings from the same coding system at different levels/classifications." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/medication-strength> ;
         fhir:reference [ fhir:v "StructureDefinition/medication-strength" ]
       ] ;
       fhir:name [ fhir:v "Medication Strength" ] ;
       fhir:description [ fhir:v "This extension applies to the Medication resource and is used to represent the strength of a medication as text. Use this extension for text representation of a medication strength as a whole. Coded representation of medication strength as a whole uses `Medication.code`." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/medication-brand-name> ;
         fhir:reference [ fhir:v "StructureDefinition/medication-brand-name" ]
       ] ;
       fhir:name [ fhir:v "Medication Brand Name" ] ;
       fhir:description [ fhir:v "This extension applies to the Medication, MedicationRequest, MedicationDispense and MedicationStatement resources and is used to represent the brand name of a medication. This extension is not to be the sole representation of the medication concept; it shall not be used as a substitute for medication code (e.g. Medication.code or MedicationStatement.medicationCodeableConcept).\n\nIf a system can only supply branded product information in text form, that information will be supplied in the text portion of that code e.g. code.text or medicationCodeableConcept.text. This extension only supports the name portion of a medication concept, not the branded product or product pack information. It is available for use for where a system needs to separate out the brand name string for handling or other processing." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/medication-generic-name> ;
         fhir:reference [ fhir:v "StructureDefinition/medication-generic-name" ]
       ] ;
       fhir:name [ fhir:v "Medication Generic Drug Name" ] ;
       fhir:description [ fhir:v "This extension applies to the Medication, MedicationRequest, MedicationDispense and MedicationStatement resources and is used to represent the generic name of a medication. The generic medication text name may not be the same as the subject medication (prescribed, dispensed or stated) but may be used to provide an additional or equivalent drug name that is a generic medication concept. This extension is not to be the sole representation of the medication concept; it shall not be used as a substitute for medication code (e.g. Medication.code or MedicationStatement.medicationCodeableConcept).\n\nIf a system can only supply generic product information, and only in text form, that information will be supplied in the text portion of that code e.g. code.text or medicationCodeableConcept.text. This extension only supports the name portion of a medication concept, not the generic product or product pack information. It is available for use for where a system needs to separate out the generic name string for handling or other processing." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ethnicity> ;
         fhir:reference [ fhir:v "StructureDefinition/ethnicity" ]
       ] ;
       fhir:name [ fhir:v "Ethnicity" ] ;
       fhir:description [ fhir:v "This extension applies to the Patient resource and is used to represent ethnic identity (see [Australian Bureau of Statistics](https://www.abs.gov.au/statistics/classifications/australian-standard-classification-cultural-and-ethnic-groups-ascceg/2019) for further information). This extension is to support the provision of healthcare services to patients with specific cultural identities. This extension provides further information about a person’s cultural values and practices which can be significant in determining service type, support required and possible needs.\n\nThe words 'ethnicity' and 'ethnic' are associated with many different meanings, but for the purpose of this extension ethnicity refers to the shared identity or similarity of a group of people on the basis of one or more distinguishing sociological characteristics, such as language, shared history, religion, cultural traditions or geographic origin etc. This extension supports Australian Aboriginal and Torres Strait Islander peoples as well as ethnicities originating from outside of Australia." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/closing-the-gap-registration> ;
         fhir:reference [ fhir:v "StructureDefinition/closing-the-gap-registration" ]
       ] ;
       fhir:name [ fhir:v "Closing the Gap Registration" ] ;
       fhir:description [ fhir:v "This extension applies to the Patient resource and provides an indicator of whether the patient is eligible for a Closing the Gap (CTG) co-payment." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/associated-healthcareservice> ;
         fhir:reference [ fhir:v "StructureDefinition/associated-healthcareservice" ]
       ] ;
       fhir:name [ fhir:v "Associated Healthcare Service" ] ;
       fhir:description [ fhir:v "This extension applies to any resource and is used to represent a healthcare service relating to a resource, e.g. healthcare services under which the patient was managed during an encounter." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/subsidised-concurrent-supply> ;
         fhir:reference [ fhir:v "StructureDefinition/subsidised-concurrent-supply" ]
       ] ;
       fhir:name [ fhir:v "Subsidised Concurrent Supply" ] ;
       fhir:description [ fhir:v "This extension applies to the MedicationRequest or MedicationDispense resources and is used to represent the grounds (e.g. [Regulation 49](https://www.pbs.gov.au/info/healthpro/explanatory-notes/section1/Section_1_2_Explanatory_Notes#Regulation-49)) that authorise a PBS or RPBS subsidy for the concurrent supply of an item specified in a prescription and all of its repeats (see [PBS](https://www.pbs.gov.au/info/healthpro/explanatory-notes/section1/Section-1-3-Explanatory-Notes) for further information)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/encounter-description> ;
         fhir:reference [ fhir:v "StructureDefinition/encounter-description" ]
       ] ;
       fhir:name [ fhir:v "Encounter Description" ] ;
       fhir:description [ fhir:v "This extension applies to the Encounter resource and is used to represent a narrative description of the healthcare event or encounter. The description may include a summary of the issues or problems, management strategies, outcomes or progress, possible prognosis, and the patient’s understanding of the healthcare event. The description may capture text about the encounter that is not captured in other fields." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/change-description> ;
         fhir:reference [ fhir:v "StructureDefinition/change-description" ]
       ] ;
       fhir:name [ fhir:v "Change Description" ] ;
       fhir:description [ fhir:v "This extension applies to the List resource and is used to represent a narrative description of the change to an item in a list entry. The narrative description may include the reason for the change to an item." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/author-related-person> ;
         fhir:reference [ fhir:v "StructureDefinition/author-related-person" ]
       ] ;
       fhir:name [ fhir:v "Author as a RelatedPerson" ] ;
       fhir:description [ fhir:v "This extension applies to any resource and is used to represent an author who is a related person." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/no-fixed-address> ;
         fhir:reference [ fhir:v "StructureDefinition/no-fixed-address" ]
       ] ;
       fhir:name [ fhir:v "No Fixed Address" ] ;
       fhir:description [ fhir:v "This extension applies to the [Address](http://hl7.org/fhir/R4/datatypes.html#Address) data type and is used to indicate that a location address is not a fixed address for an individual." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/identifier-routability> ;
         fhir:reference [ fhir:v "StructureDefinition/identifier-routability" ]
       ] ;
       fhir:name [ fhir:v "Identifier Routability" ] ;
       fhir:description [ fhir:v "This extension applies to the [Identifier](http://hl7.org/fhir/datatypes.html#identifier) data type. Identifier routability preferences for an asserter." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ihi-status> ;
         fhir:reference [ fhir:v "StructureDefinition/ihi-status" ]
       ] ;
       fhir:name [ fhir:v "IHI Status" ] ;
       fhir:description [ fhir:v "This extension applies to the [Identifier](http://hl7.org/fhir/datatypes.html#identifier) data type and is used to represent the status of the associated Individual Healthcare Identifier (IHI) and indicates whether the status of the IHI is active or otherwise." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ihi-record-status> ;
         fhir:reference [ fhir:v "StructureDefinition/ihi-record-status" ]
       ] ;
       fhir:name [ fhir:v "IHI Record Status" ] ;
       fhir:description [ fhir:v "This extension applies to the [Identifier](http://hl7.org/fhir/datatypes.html#identifier) data type and is used to indicate whether verification of the Individual Healthcare Identifier (IHI) has occurred and is based on the evidence available for a person’s identity." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ihi-verified-date> ;
         fhir:reference [ fhir:v "StructureDefinition/ihi-verified-date" ]
       ] ;
       fhir:name [ fhir:v "IHI Verification Date" ] ;
       fhir:description [ fhir:v "This extension applies to the [Identifier](http://hl7.org/fhir/datatypes.html#identifier) data type and is used to represent the date, and optionally time, that the IHI was verified with HI Services. This is not the date that it was created by the HI Services, but when it was checked. This is often required to know how recently the identifier was checked, and if it must be re-verified before using it." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/date-accuracy-indicator> ;
         fhir:reference [ fhir:v "StructureDefinition/date-accuracy-indicator" ]
       ] ;
       fhir:name [ fhir:v "Date Accuracy Indicator" ] ;
       fhir:description [ fhir:v "This extension applies to the [date](http://hl7.org/fhir/R4/datatypes.html#date) and [dateTime](http://hl7.org/fhir/R4/datatypes.html#dateTime) data types and is used to represent the accuracy of the associated date." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/information-recipient> ;
         fhir:reference [ fhir:v "StructureDefinition/information-recipient" ]
       ] ;
       fhir:name [ fhir:v "Information Recipient" ] ;
       fhir:description [ fhir:v "This extension applies to the Composition resource and is used to represent an intended recipient of the composition." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/vaccine-serial-number> ;
         fhir:reference [ fhir:v "StructureDefinition/vaccine-serial-number" ]
       ] ;
       fhir:name [ fhir:v "Vaccine Vial Serial Number" ] ;
       fhir:description [ fhir:v "This extension applies to the Immunization resource and is used to represent the serial number of the vial of vaccine. Vial serial number is part of the [Australian Immunisation Register Rule 2015](https://www.legislation.gov.au/Latest/F2021C00234) data elements to report for COVID-19 vaccines." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/veteran-status> ;
         fhir:reference [ fhir:v "StructureDefinition/veteran-status" ]
       ] ;
       fhir:name [ fhir:v "Australian Veteran Status" ] ;
       fhir:description [ fhir:v "This extension applies to the Patient resource and is used to indicate whether a person is serving, or has served, in the Australian Defence Force." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/result-copies-to> ;
         fhir:reference [ fhir:v "StructureDefinition/result-copies-to" ]
       ] ;
       fhir:name [ fhir:v "Result Copies To" ] ;
       fhir:description [ fhir:v "This extension applies to the ServiceRequest resource and is used to indicate an additional recipient to whom a copy of the outcome of the request (i.e. the results) should be sent. The service requester will typically receive a result as part of the normal processing from the filler of the request and this extension is only relevant for any additional result copy recipients indicated on the request." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-patient> ;
         fhir:reference [ fhir:v "StructureDefinition/au-patient" ]
       ] ;
       fhir:name [ fhir:v "AU Base Patient" ] ;
       fhir:description [ fhir:v "This profile defines a patient structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-practitioner> ;
         fhir:reference [ fhir:v "StructureDefinition/au-practitioner" ]
       ] ;
       fhir:name [ fhir:v "AU Base Practitioner" ] ;
       fhir:description [ fhir:v "This profile defines a practitioner structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-practitionerrole> ;
         fhir:reference [ fhir:v "StructureDefinition/au-practitionerrole" ]
       ] ;
       fhir:name [ fhir:v "AU Base PractitionerRole" ] ;
       fhir:description [ fhir:v "This profile defines a practitioner role structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-relatedperson> ;
         fhir:reference [ fhir:v "StructureDefinition/au-relatedperson" ]
       ] ;
       fhir:name [ fhir:v "AU Base RelatedPerson" ] ;
       fhir:description [ fhir:v "This profile defines a related person structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-organization> ;
         fhir:reference [ fhir:v "StructureDefinition/au-organization" ]
       ] ;
       fhir:name [ fhir:v "AU Base Organization" ] ;
       fhir:description [ fhir:v "This profile defines an organisation structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-medication> ;
         fhir:reference [ fhir:v "StructureDefinition/au-medication" ]
       ] ;
       fhir:name [ fhir:v "AU Base Medication" ] ;
       fhir:description [ fhir:v "This profile defines a medication structure that localises core concepts, including terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-encounter> ;
         fhir:reference [ fhir:v "StructureDefinition/au-encounter" ]
       ] ;
       fhir:name [ fhir:v "AU Base Encounter" ] ;
       fhir:description [ fhir:v "This profile defines an encounter structure that localises core concepts, including terminology, for use in an Australian context. This profile is intended to be applicable for recording details of ambulatory and non-ambulatory patient encounters in an Australian healthcare context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address> ;
         fhir:reference [ fhir:v "StructureDefinition/au-address" ]
       ] ;
       fhir:name [ fhir:v "Australian Address" ] ;
       fhir:description [ fhir:v "This profile defines an address structure that localises core concepts, including identifiers and terminology, for use in an Australian context, to specifically represent an Australian (location) address. The purpose of this profile is to provide best practice guidance on Australian address representation, where some constraint on content is desirable to guarantee the quality of an Australian address." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-ihi> ;
         fhir:reference [ fhir:v "StructureDefinition/au-ihi" ]
       ] ;
       fhir:name [ fhir:v "AU IHI" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Individual Healthcare Identifier in an Australian context (see [Australian Digital Health Agency](https://developer.digitalhealth.gov.au/specifications/national-infrastructure/ep-1826-2014/nehta-1163-2010) for further information). An IHI is assigned under the Healthcare Identifiers (HI) Service to a patient." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-nationalprovideridentifieratorganisation> ;
         fhir:reference [ fhir:v "StructureDefinition/au-nationalprovideridentifieratorganisation" ]
       ] ;
       fhir:name [ fhir:v "AU National Provider Identifier At Organisation" ] ;
       fhir:description [ fhir:v "This identifier profile defines a National Provider Identifier at Organisation (NPIO) in an Australian context. An NPIO identifies an individual practitioner at an organisation using the practitioner's HPI-I and organisation's HPI-O to form the NPIO." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-medicarecardnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-medicarecardnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Medicare Card Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Medicare card number in an Australian context. A Medicare card is provided to individuals who are enrolled in [Medicare](https://www.servicesaustralia.gov.au/individuals/medicare). This definition supports sending either the 10 digit Medicare card number or the 11 digit number (includes the individual reference number (IRN))." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-medicareprovidernumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-medicareprovidernumber" ]
       ] ;
       fhir:name [ fhir:v "AU Medicare Provider Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Medicare provider number assigned by Services Australia to practitioners who provide services covered by the Medicare Benefits Schedule (MBS) at a specific location. A practitioner may have more than one Medicare provider number if they deliver health services in different locations or are registered in multiple health professions." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pbsprescribernumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pbsprescribernumber" ]
       ] ;
       fhir:name [ fhir:v "AU PBS Prescriber Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Pharmaceutical Benefits Scheme (PBS) prescriber number in an Australian context (see [PBS](https://www.pbs.gov.au/info/healthpro/explanatory-notes/section1/Section_1_2_Explanatory_Notes) for further information). A PBS prescriber number, previously referred to as Medicare prescriber number in earlier versions of this implementation guide, is assigned by Services Australia under the Pharmaceutical Benefits Scheme to practitioners who are approved to prescribe PBS medicines under the National Health Act 1953." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-medicalrecordnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-medicalrecordnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Medical Record Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a  (MRN) (sometimes referred to as unit record number (URN) or (UR)) in an Australian context. An MRN is an institution's identifier for a patient's record at that institution. A patient may have more than one MRN for a single institution due to organisational restructures." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-hpii> ;
         fhir:reference [ fhir:v "StructureDefinition/au-hpii" ]
       ] ;
       fhir:name [ fhir:v "AU HPI-I" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Healthcare Provider Identifier - Individual (HPI-I) in an Australian context (see [Australian Digital Health Agency](https://developer.digitalhealth.gov.au/specifications/national-infrastructure/ep-1826-2014/nehta-1163-2010) for further information). An HPI-I is assigned under the HI Service to healthcare providers involved in providing patient care." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-dvanumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-dvanumber" ]
       ] ;
       fhir:name [ fhir:v "AU DVA Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Department of Veterans' Affairs (DVA) number) in an Australian context. This definition supports sending an individual's state-based DVA file number as displayed on a [Veteran Card](https://www.dva.gov.au/health-and-treatment/veteran-healthcare-cards/veteran-card), i.e. a Gold, White, or Orange Card. A Veteran Card may be issued by DVA to eligible individuals to allowing access to specific goods and services at a concessional rate." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-hpio> ;
         fhir:reference [ fhir:v "StructureDefinition/au-hpio" ]
       ] ;
       fhir:name [ fhir:v "AU HPI-O" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Healthcare Provider Identifier – Organisation in an Australian context (see [Australian Digital Health Agency](https://developer.digitalhealth.gov.au/specifications/national-infrastructure/ep-1826-2014/nehta-1163-2010) for further information). An HPI-O is assigned under the HI Service to an organisation (such as a hospital or medical clinic) where healthcare is provided." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-ahpraregistrationnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-ahpraregistrationnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Ahpra Registration Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Australian Health Practitioner Regulation Agency (Ahpra) registration number in an Australian context (see [Ahpra](https://www.ahpra.gov.au) for further information)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-australianbusinessnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-australianbusinessnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Australian Business Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Australian Business Number (ABN) in an Australian context. An ABN is issued to all entities registered in the Australian Business Register (ABR)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-australianregistredbodynumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-australianregistredbodynumber" ]
       ] ;
       fhir:name [ fhir:v "AU Australian Registered Body Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Australian Registered Body Number (ARBN) in an Australian context. ARBNs are issued to registrable Australian bodies and foreign companies." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-paididentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-paididentifier" ]
       ] ;
       fhir:name [ fhir:v "AU PAI-D Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a My Health Record Assigned Identity - Device (PAI-D) identifier in an Australian context. A PAI-D is typically used to identify a device that plays a role, for example an authoring or observing, in the exchange of digital health data with the My Health Record system." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-paioidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-paioidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU PAI-O Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a My Health Record Assigned Identity - Organisation (PAI-O) identifier in an Australian context. A PAI-O may be issued to organisations who wish to participate in the My Health Record and who are not eligible for a Healthcare Provider Identifier - Organisation (HPI-O)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-careagencyemployeeidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-careagencyemployeeidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU Care Agency Employee Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a care agency employee (CAE) identifier in an Australian context. A CAE identifier may be issued to an employee of, or person under contracted arrangement with, a care agency who wishes to participate in the My Health Record." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-etpprescriptionidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-etpprescriptionidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU ETP Prescription Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Electronic Transfer of Prescription (ETP) prescription identifier in an Australian context. An ETP prescription identifier is assigned to a prescription by an ETP vendor, e.g. ERx or Medisecure, and is the assigned numeric value of the barcode on a prescription instance." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-nataaccreditationnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-nataaccreditationnumber" ]
       ] ;
       fhir:name [ fhir:v "AU NATA Accreditation Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a National Association of Testing Authorities (NATA) accreditation number in an Australian context (see [NATA](https://www.nata.com.au/) for further information)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-natasitenumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-natasitenumber" ]
       ] ;
       fhir:name [ fhir:v "AU NATA Site Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a National Association of Testing Authorities (NATA) site number in an Australian context (see [NATA](https://www.nata.com.au/) for further information)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-locationspecificpracticenumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-locationspecificpracticenumber" ]
       ] ;
       fhir:name [ fhir:v "AU Location Specific Practice Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Location Specific Practice Number (LSPN) in an Australian context (see [Services Australia](https://www.servicesaustralia.gov.au/organisations/health-professionals/services/medicare/medicare-eligibility-provide-diagnostic-imaging-and-radiation-oncology-services#a2) and [Department of Health and Aged Care](https://www1.health.gov.au/internet/main/publishing.nsf/Content/stage-two-diag-img-acc-scheme-loc-spec-prac-num-fact-sheet) for further information). An LSPN is an identifier assigned to a specific location by Services Australia under the Medicare program and identifies an accredited practice site that provides diagnostic imaging and radiation oncology services." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-employeenumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-employeenumber" ]
       ] ;
       fhir:name [ fhir:v "AU Employee Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an employee number (sometimes referred to as an employee identifier (EI)) in an Australian context. An employee number is an organisation's identifier for an individual employed by that organisation." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-cspregistrationnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-cspregistrationnumber" ]
       ] ;
       fhir:name [ fhir:v "AU CSP Registration Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Contracted Service Provider (CSP) registration number in an Australian context (see [My Health Record](https://www.myhealthrecord.gov.au/for-healthcare-professionals/howtos/contracted-service-provider-registration) for further information). A CSP registration number may be issued to organisations who wish to participate in the My Health Record and/or the Healthcare Identifiers Service as a CSP." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-healthcarecardnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-healthcarecardnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Health Care Card Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines Health Care Card number in an Australian context (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/services/centrelink/health-care-card) for further information).\n\nThis definition supports sending the Centrelink Customer Reference Number (CRN) (also referred to as unique identifier number (UIN) in the Centrelink Confirmation eServices (CCeS)) as displayed on the individual's Health Care Card (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/subjects/centrelink-customer-reference-number-crn) for further information). An individual's CRN is present as the primary identifier on different concession cards and is used to confirm concessions by most government agencies and utility providers.\n\nA Health Care Card is a concession card assigned by Services Australia to benefit recipients, low income earners and selected other groups (e.g. foster children) to assist with certain health costs, by allowing access to specific services at a concessional rate." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-australiancompanynumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-australiancompanynumber" ]
       ] ;
       fhir:name [ fhir:v "AU Australian Company Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Australian Company Number in an Australian context. An ACN is allocated by the Australian Securities and Investments Commission (ASIC) when a body becomes registered as a company under Corporations Law." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-cwlthseniorshealthcardnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-cwlthseniorshealthcardnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Commonwealth Seniors Health Card Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Commonwealth Seniors Health Card number in an Australian context (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/services/centrelink/commonwealth-seniors-health-card) or [Department of Veterans' Affairs](https://www.dva.gov.au/health-and-treatment/veteran-healthcare-cards/commonwealth-seniors-health-card) for further information).\n\nThis definition supports sending the Centrelink Customer Reference Number (CRN) (also referred to as unique identifier number (UIN) in the Centrelink Confirmation eServices (CCeS)) as displayed on the individual's Commonwealth Seniors Health Card (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/subjects/centrelink-customer-reference-number-crn) for further information). An individual's CRN is present as the primary identifier on different concession cards and is used to confirm concessions by most government agencies and utility providers.\n\nA Commonwealth Seniors Health Card may be issued by Services Australia or Department of Veterans' Affairs (DVA) to retirees of age pension qualification age to assist with certain living costs by allowing access to specific goods and services at a concessional rate." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pensionerconcessioncardnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pensionerconcessioncardnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Pensioner Concession Card Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Pensioner Concession Card number in an Australian context (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/services/centrelink/pensioner-concession-card) or [Department of Veterans' Affairs](https://www.dva.gov.au/health-and-treatment/veteran-healthcare-cards/pensioner-concession-card)).\n\nThis definition supports sending the Centrelink Customer Reference Number (CRN) (also referred to as unique identifier number (UIN) in the Centrelink Confirmation eServices (CCeS)) as displayed on the individual's Pensioner Concession Card (see [Services Australia](https://www.servicesaustralia.gov.au/individuals/subjects/centrelink-customer-reference-number-crn) for further information). An individual's CRN is present as the primary identifier on different concession cards and is used to confirm concessions by most government agencies and utility providers.\n\nA Pensioner Concession Card may be issued by Services Australia or Department of Veterans' Affairs (DVA) to pensioners and selected benefit recipients to assist them with certain living costs, by allowing access to specific goods and services at a concessional rate." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-insurancemembernumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-insurancemembernumber" ]
       ] ;
       fhir:name [ fhir:v "AU Insurance Member Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines an insurance member number in an Australian context. An insurance member number is the unique member number assigned to an individual by an insurer and is typically displayed on their insurance card. An individual will not have more than one member number per insurer.\n\nThis definition supports the sending of an insurance member number that is relevant in a healthcare context and may be used to capture Australian and International health insurer issued member numbers. In Australia this will typically be a private health insurance member number. This identifier should not be confused with an insurance policy number." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
