         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-diagnosticresult> ;
         fhir:reference [ fhir:v "StructureDefinition/au-diagnosticresult" ]
       ] ;
       fhir:name [ fhir:v "AU Base Diagnostic Result" ] ;
       fhir:description [ fhir:v "This profile defines an observation structure to represent a diagnostic investigation result issued by a diagnostic service provider in an Australian context. This profile may be used to represent a specialist or other diagnostic (not imaging or pathology) observation including results of audiology studies, sleep studies or speech pathology. The observation may represent the result of a simple investigation or it may group the set of results of a multi-modality procedure or multi-test study / panel." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pathologyresult> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pathologyresult" ]
       ] ;
       fhir:name [ fhir:v "AU Base Pathology Result" ] ;
       fhir:description [ fhir:v "This profile defines an observation structure to represent a pathology test result issued by a diagnostic service provider in an Australian context. This profile is intended to be capable of supporting reporting for all pathology disciplines (e.g. including microbiology, histopathology, cytology, blood transfusion) with the exception of genomics. The observation may represent the result of a simple test such as haemoglobin or it may group the set of results produced by a multi-test study or panel such as a full blood count, or urine specimen study.\n\nThis profile does not provide full support for structured pathology reporting. It is expected that this support is best handled by a set of profiles that represent the structured reporting requirements for each specific protocol (see for example [RCPA’s structured pathology reporting of cancer](https://www.rcpa.edu.au/Library/Practising-Pathology/Structured-Pathology-Reporting-of-Cancer)); this is not in the scope of this implementation guide at this time." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-imagingresult> ;
         fhir:reference [ fhir:v "StructureDefinition/au-imagingresult" ]
       ] ;
       fhir:name [ fhir:v "AU Base Diagnostic Imaging Result" ] ;
       fhir:description [ fhir:v "This profile defines an observation structure to represent a imaging examination result issued by a diagnostic service provider in an Australian context. The observation may represent the conclusions of a diagnostic procedure such as Left retina Foveal thickness by OCT, or it may group the set of results produced by a multi-test study or panel such as Biophysical profile panel." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-imagingreport> ;
         fhir:reference [ fhir:v "StructureDefinition/au-imagingreport" ]
       ] ;
       fhir:name [ fhir:v "AU Base Diagnostic Imaging Report" ] ;
       fhir:description [ fhir:v "This profile defines a diagnostic report structure to represent a diagnostic imaging report issued by a diagnostic service provider in an Australian context." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-diagnosticreport> ;
         fhir:reference [ fhir:v "StructureDefinition/au-diagnosticreport" ]
       ] ;
       fhir:name [ fhir:v "AU Base DiagnosticReport" ] ;
       fhir:description [ fhir:v "This profile defines a diagnostic report structure that localises core concepts, including identifiers and terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs.\n\nFor specific reporting of pathology or imaging services the more specific [AU Base Pathology Report](StructureDefinition-au-pathologyreport.html) or [AU Base Diagnostic Imaging Report](StructureDefinition-au-imagingreport.html) profiles would be preferred. This profile is suitable for any other diagnostic service reporting needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pathologyreport> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pathologyreport" ]
       ] ;
       fhir:name [ fhir:v "AU Base Pathology Report" ] ;
       fhir:description [ fhir:v "This profile defines a diagnostic report structure to represent a pathology report issued by a diagnostic service provider in an Australian context. This profile is intended to be capable of supporting reporting for all pathology disciplines (e.g. including microbiology, histopathology, cytology, blood transfusion) with the exception of genomics.\n\nThis profile does not provide full support for structured pathology reporting. It is expected that this support is best handled by a set of profiles that represent the structured reporting requirements for each specific protocol (see for example [RCPA’s structured pathology reporting of cancer](https://www.rcpa.edu.au/Library/Practising-Pathology/Structured-Pathology-Reporting-of-Cancer)); this is not in the scope of this implementation guide at this time." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-specimen> ;
         fhir:reference [ fhir:v "StructureDefinition/au-specimen" ]
       ] ;
       fhir:name [ fhir:v "AU Base Specimen" ] ;
       fhir:description [ fhir:v "This profile defines a specimen structure that localises core concepts, including terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/contact-purpose> ;
         fhir:reference [ fhir:v "StructureDefinition/contact-purpose" ]
       ] ;
       fhir:name [ fhir:v "Contact Purpose" ] ;
       fhir:description [ fhir:v "This extension applies to the [ContactPoint](http://hl7.org/fhir/datatypes.html#ContactPoint) data type and is used to represent the purpose for which a contact can be reached, e.g. after hours or billing." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-deliverypointidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-deliverypointidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU Delivery Point Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines an Australia Post Delivery Point Identifier (DPID) in an Australian context (see [Australia Post](https://auspost.com.au/content/dam/auspost_corp/media/documents/australia-post-data-guide.pdf) for further information). A DPID is a randomly generated, unique 8-digit number, allocated by Australia Post to an address. A DPID enables each delivery point in Australia to be uniquely identified." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-gnafidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-gnafidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU G-NAF Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a Geocoded National Address File (G-NAF) identifier in an Australian context. The [PSMA G-NAF](https://data.gov.au/data/dataset/geocoded-national-address-file-g-naf) is Australia’s authoritative, geocoded address file. A G-NAF identifier (sometimes referred to as G-NAF ID, or G-NAF PID, or GNAF ID, or address_detail_pid) identifies an address in the PSMA G-NAF." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/address-identifier> ;
         fhir:reference [ fhir:v "StructureDefinition/address-identifier" ]
       ] ;
       fhir:name [ fhir:v "Address Identifier" ] ;
       fhir:description [ fhir:v "This extension applies to the [Address](http://hl7.org/fhir/R4/datatypes.html#Address) data type and is used to represent an identifier for an address. An address identifier does not form part of the address itself, e.g. a street number. It is a unique identifier associated with a location address and may be used to look up an address, validate an address, or link to other data relating to an address." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pharmacyapprovalnumber> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pharmacyapprovalnumber" ]
       ] ;
       fhir:name [ fhir:v "AU Pharmacy Approval Number" ] ;
       fhir:description [ fhir:v "This identifier profile defines a pharmacy approval number in an Australian context (see [Department of Health and Aged Care](https://www1.health.gov.au/internet/main/publishing.nsf/Content/pharmaceutical-benefits-scheme-approved-supplier-administrative-functions) for further information). A pharmacy approval number, also known as a PBS approval number, is assigned by the Department of Health to pharmacies that are approved to supply pharmaceutical benefits at particular premises under the National Health Act 1953." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ahpraregistration-details> ;
         fhir:reference [ fhir:v "StructureDefinition/ahpraregistration-details" ]
       ] ;
       fhir:name [ fhir:v "Ahpra Registration Details" ] ;
       fhir:description [ fhir:v "This extension applies to the Practitioner.qualification element and is used to represent Australian Health Practitioner Regulation Agency (Ahpra) registration details (see [Ahpra](https://www.ahpra.gov.au/Support/Glossary.aspx#Registration%20Number) for further information). This extension supports the inclusion of the Ahpra profession code and information about division, speciality, registration status, endorsements and notations in a qualification element instance representing a practitioner’s Ahpra registration." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/ahpraprofession-details> ;
         fhir:reference [ fhir:v "StructureDefinition/ahpraprofession-details" ]
       ] ;
       fhir:name [ fhir:v "Ahpra Profession Details" ] ;
       fhir:description [ fhir:v "This extension applies to the Practitioner.qualification element and is used to represent Australian Health Practitioner Regulation Agency (Ahpra) profession details (see [Ahpra](https://www.ahpra.gov.au/Support/Glossary.aspx#Registration%20Number) for further information). This extension supports the inclusion of the Ahpra profession code and information about conditions, undertakings, reprimands and cautions in a qualification element instance representing a practitioner’s Ahpra profession." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-substance> ;
         fhir:reference [ fhir:v "StructureDefinition/au-substance" ]
       ] ;
       fhir:name [ fhir:v "AU Base Substance" ] ;
       fhir:description [ fhir:v "This profile defines a substance structure that localises core concepts, including terminology, for use in an Australian context. The purpose of this profile is to provide national level agreement on core localised concepts. This profile does not force conformance to core localised concepts. It enables implementers and modellers to make their own rules, i.e. [profiling](http://hl7.org/fhir/profiling.html), about how to support these concepts for specific implementation needs." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pi> ;
         fhir:reference [ fhir:v "StructureDefinition/au-pi" ]
       ] ;
       fhir:name [ fhir:v "AU Patient Internal Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a patient internal identifier in an Australian context. A patient internal identifier is assigned to a patient by an application (e.g. practice management system or a cloud-based electronic medical record) to uniquely identify a patient within that application.\n\nWhile a patient internal identifier can be exchanged with other applications, its scope for sharing is limited and typically occurs for context-specific patient matching (e.g. a patient internal identifier included in a pathology request can be returned in the associated pathology report). This identifier is only unique within the assigning application and is not suitable for broader use as a persistent identifier, unlike a Medical Record Number (MRN), which is unique within an institution." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/contact-purpose> ;
         fhir:reference [ fhir:v "ValueSet/contact-purpose" ]
       ] ;
       fhir:name [ fhir:v "Contact Purpose" ] ;
       fhir:description [ fhir:v "The purpose for which an associated contact can be reached." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/au-v3-ActEncounterCode-extended> ;
         fhir:reference [ fhir:v "ValueSet/au-v3-ActEncounterCode-extended" ]
       ] ;
       fhir:name [ fhir:v "ActEncounterCode - AU Extended" ] ;
       fhir:description [ fhir:v "v3 Act Encounter Code extended for use in an Australian context. Includes HL7 international codes plus Australian additions to create a complete set." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/au-v2-0203-extended> ;
         fhir:reference [ fhir:v "ValueSet/au-v2-0203-extended" ]
       ] ;
       fhir:name [ fhir:v "hl7VS-identifierType - AU Extended" ] ;
       fhir:description [ fhir:v "Extended value set of identifier types for use in an Australian context. Includes HL7 international codes plus Australian additions to create a complete set. NOTE: codes contained LACN Laboratory Accession ID and ACN Accession ID are exclusive concepts and not consider related in this terminology." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
