           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-localprescriptionidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-localprescriptionidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU Local Prescription Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a local prescription identifier (sometimes referred to as prescription number) in an Australian context. A local prescription identifier is an organisation's identifier for a prescription in that organisation's local system set of prescriptions. A local prescription identifier allows linking of a prescription to a system's local identifier." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-localdispenseidentifier> ;
         fhir:reference [ fhir:v "StructureDefinition/au-localdispenseidentifier" ]
       ] ;
       fhir:name [ fhir:v "AU Local Dispense Identifier" ] ;
       fhir:description [ fhir:v "This identifier profile defines a local dispense identifier in an Australian context. A local dispense identifier is an organisation's identifier for a dispense record in that organisation's local system set of dispense records. A dispense record identifier is typically assigned by the dispensing system and allows linking of a dispensing record to the dispensing system's local identifier." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
