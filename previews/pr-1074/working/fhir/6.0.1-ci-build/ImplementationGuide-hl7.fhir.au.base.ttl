           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-medlist> ;
         fhir:reference [ fhir:v "StructureDefinition/au-medlist" ]
       ] ;
       fhir:name [ fhir:v "AU Medicine List" ] ;
       fhir:description [ fhir:v "This profile defines a list structure that localises core concepts for use as a medicines list in an Australian context. This profile is intended to offer a common structure and expectations for a list of medications associated with a patient in an Australian healthcare context." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
