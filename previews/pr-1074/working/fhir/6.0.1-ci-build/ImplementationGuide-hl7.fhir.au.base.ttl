         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/au-v2-0443-extended> ;
         fhir:reference [ fhir:v "ValueSet/au-v2-0443-extended" ]
       ] ;
       fhir:name [ fhir:v "hl7VS-providerRole - AU Extended" ] ;
       fhir:description [ fhir:v "hl7VS-providerRole extended for use in an Australian context. Includes HL7 international codes plus Australian additions to create a complete set." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/service-provision-conditions> ;
         fhir:reference [ fhir:v "ValueSet/service-provision-conditions" ]
       ] ;
       fhir:name [ fhir:v "Service Provision Conditions Australian Concepts" ] ;
       fhir:description [ fhir:v "The Service Provision Conditions Australian Concepts value set includes values that may be used to identify the type of service provision conditions in an Australian context." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/CodeSystem/pbs-item-external> ;
         fhir:reference [ fhir:v "CodeSystem/pbs-item-external" ]
       ] ;
       fhir:name [ fhir:v "PBS Item Codes" ] ;
       fhir:description [ fhir:v "This CodeSystem resource represents the items listed on the Australian Pharmaceutical Benefits Scheme (PBS) schedule published by the Department of Health. Codes are represented as five or six characters in format (n)nnnna and the display is the PBS prescribing rule preferred term. This is not the canonical publication of this code system nor it is intended to be publication on behalf of the Department of Health. For the complete content of the code system contact the publisher." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/pbs-item> ;
         fhir:reference [ fhir:v "ValueSet/pbs-item" ]
       ] ;
       fhir:name [ fhir:v "PBS Item Codes" ] ;
       fhir:description [ fhir:v "The PBS Item Codes value set includes all values from Australian Pharmaceutical Benefits Scheme (PBS) schedule published by the Department of Health. Further details can be found at https://www.pbs.gov.au/pbs/." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/mims> ;
         fhir:reference [ fhir:v "ValueSet/mims" ]
       ] ;
       fhir:name [ fhir:v "MIMS" ] ;
       fhir:description [ fhir:v "The MIMS value set includes all values from the Monthly Index of Medical Specialties (MIMS) published by MIMS Australia. Further details can be found at https://www.mims.com.au/." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/CodeSystem/mims-external> ;
         fhir:reference [ fhir:v "CodeSystem/mims-external" ]
       ] ;
       fhir:name [ fhir:v "Monthly Index of Medical Specialties (MIMS)" ] ;
       fhir:description [ fhir:v "This CodeSystem resource represents the Monthly Index of Medical Specialties (MIMS) code system published by MIMS Australia. The intended use of MIMS data is to fully specify the product as a combination of product code, form code, and pack code. For example, when providing a MIMS Code within a Clinical Document Architecture (CDA) document, the MIMS code will be a minimum of 5 digits (in most cases, will be 8 digits).This is not the canonical publication of this code system nor it is intended to be publication on behalf of the MIMS Australia. For the complete content of the code system contact the publisher." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/amt-mp-codes> ;
         fhir:reference [ fhir:v "ValueSet/amt-mp-codes" ]
       ] ;
       fhir:name [ fhir:v "AMT Medicinal Product and Substances" ] ;
       fhir:description [ fhir:v "The AMT Medicinal Product and Substances value set includes values that may be used to identify a substance or a medicinal product that is an ingredient of a medication." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/medication-type> ;
         fhir:reference [ fhir:v "ValueSet/medication-type" ]
       ] ;
       fhir:name [ fhir:v "Medication Type" ] ;
       fhir:description [ fhir:v "The Medication Type value set may be used to classify the nature of properties defined by the code e.g. branded product with no strength or form. This allows the distinction between codes provided containing container, pack, strength and form explicitly especially where terminologies supplied are unknown or terminology services are unavailable." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/dva-entitlement> ;
         fhir:reference [ fhir:v "ValueSet/dva-entitlement" ]
       ] ;
       fhir:name [ fhir:v "DVA Entitlement" ] ;
       fhir:description [ fhir:v "Entitlement types that may be associated with an individual's Department of Veterans’ Affairs (DVA) File Number on a DVA issued health card in an Australian context." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/accession-number-type> ;
         fhir:reference [ fhir:v "ValueSet/accession-number-type" ]
