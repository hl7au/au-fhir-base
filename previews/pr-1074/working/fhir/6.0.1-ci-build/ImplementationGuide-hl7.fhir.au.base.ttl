         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://hl7.org.au/fhir/ValueSet/au-v2-0360-extended> ;
         fhir:reference [ fhir:v "ValueSet/au-v2-0360-extended" ]
       ] ;
       fhir:name [ fhir:v "hl7VS-degreeLicenseCertificate - AU Extended" ] ;
       fhir:description [ fhir:v "hl7VS-degreeLicenseCertificate extended for use in an Australian context. Includes HL7 international codes plus Australian additions to create a complete set." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
