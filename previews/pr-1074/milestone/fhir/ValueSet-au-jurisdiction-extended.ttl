  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet au-jurisdiction-extended</b></p><a name=\"au-jurisdiction-extended\"> </a><a name=\"hcau-jurisdiction-extended\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profile: <code>https://healthterminologies.gov.au/fhir/StructureDefinition/composed-value-set-4</code></p></div><p>This value set includes codes based on the following rules:</p><ul><li>Import all the codes that are contained in <a href=\"http://terminology.hl7.org/7.2.0/ValueSet-jurisdiction.html\">Jurisdiction ValueSet</a></li><li>Include these codes as defined in <a href=\"https://tx.hl7.org.au/fhir\"><code>https://healthterminologies.gov.au/fhir/CodeSystem/australian-states-territories-1</code></a><span style=\"opacity: 0.5\" title=\"Version is not explicitly stated. When building this specification, the most recent version 1.1.3 has been used\"> version ⏿1.1.3</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-ACT\">ACT</a></td><td style=\"color: #cccccc\">Australian Capital Territory</td><td>Australian Capital Territory</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-NSW\">NSW</a></td><td style=\"color: #cccccc\">New South Wales</td><td>New South Wales</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-NT\">NT</a></td><td style=\"color: #cccccc\">Northern Territory</td><td>Northern Territory</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-QLD\">QLD</a></td><td style=\"color: #cccccc\">Queensland</td><td>Queensland</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-SA\">SA</a></td><td style=\"color: #cccccc\">South Australia</td><td>South Australia</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-TAS\">TAS</a></td><td style=\"color: #cccccc\">Tasmania</td><td>Tasmania</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-VIC\">VIC</a></td><td style=\"color: #cccccc\">Victoria</td><td>Victoria</td></tr><tr><td><a href=\"https://tx.hl7.org.au/fhir/ValueSet/australian-states-territories-1#australian-states-territories-1-WA\">WA</a></td><td style=\"color: #cccccc\">Western Australia</td><td>Western Australia</td></tr></table></li></ul></div>"^^rdf:XMLLiteral ]
