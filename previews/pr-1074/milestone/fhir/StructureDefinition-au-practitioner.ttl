           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-practitioner>
         ]
       ] [
         fhir:key [ fhir:v "inv-pra-2" ] ;
         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "Recorded sex or gender type shall be a member of the AU Recorded Sex or Gender Type value set if any codes within that value set can apply" ] ;
         fhir:expression [ fhir:v "extension('http://hl7.org/fhir/StructureDefinition/individual-recordedSexOrGender').extension('type').empty() or extension('http://hl7.org/fhir/StructureDefinition/individual-recordedSexOrGender').extension('type').value.all(memberOf('http://terminology.hl7.org.au/ValueSet/rsg-type'))" ] ;
         fhir:source [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-practitioner"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-practitioner>
         ]
       ] [
         fhir:key [ fhir:v "inv-pra-3" ] ;
         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "Recorded sex or gender source document type shall be a member of the AU Recorded Sex or Gender (RSG) Source Document Type value set if any codes within that value set can apply" ] ;
         fhir:expression [ fhir:v "extension('http://hl7.org/fhir/StructureDefinition/individual-recordedSexOrGender').extension('sourceDocument').empty() or extension('http://hl7.org/fhir/StructureDefinition/individual-recordedSexOrGender').extension('sourceDocument').value.ofType(CodeableConcept).all(memberOf('http://terminology.hl7.org.au/ValueSet/rsg-source-document-type'))" ] ;
         fhir:source [
