           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-hpii>
         ] [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-pbsprescribernumber"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-pbsprescribernumber>
         ] [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-careagencyemployeeidentifier"^^xsd:anyURI ;
