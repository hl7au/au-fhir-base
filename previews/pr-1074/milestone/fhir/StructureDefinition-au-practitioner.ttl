           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-ahpraregistrationnumber>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Practitioner.address" ] ;
       fhir:path [ fhir:v "Practitioner.address" ] ;
       fhir:comment [ fhir:v "The address is intended to describe postal addresses for administrative purposes, not to describe absolute geographical coordinates. Postal addresses are often used as proxies for physical locations (also see the Location resource)." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Address"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Address"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Address>
         ] [
           fhir:v "http://hl7.org.au/fhir/StructureDefinition/au-address"^^xsd:anyURI ;
           fhir:link <http://hl7.org.au/fhir/StructureDefinition/au-address>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Practitioner.qualification" ] ;
       fhir:path [ fhir:v "Practitioner.qualification" ]
     ] [
       fhir:id [ fhir:v "Practitioner.qualification.code" ] ;
       fhir:path [ fhir:v "Practitioner.qualification.code" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "preferred" ] ;
         fhir:valueSet [
           fhir:v "http://terminology.hl7.org.au/ValueSet/v2-0360-extended"^^xsd:anyURI ;
           fhir:link <http://terminology.hl7.org.au/ValueSet/v2-0360-extended>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Practitioner.communication" ] ;
       fhir:path [ fhir:v "Practitioner.communication" ] ;
