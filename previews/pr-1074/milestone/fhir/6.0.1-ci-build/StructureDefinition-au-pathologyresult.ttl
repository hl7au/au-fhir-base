       ] )
     ] [
       fhir:id [ fhir:v "Observation.component.interpretation" ] ;
       fhir:path [ fhir:v "Observation.component.interpretation" ] ;
       fhir:short [ fhir:v "High, low, normal, etc." ] ;
       fhir:definition [ fhir:v "A categorical assessment of an observation value.  For example, high, low, normal." ] ;
       fhir:comment [ fhir:v "Historically used for laboratory results (known as 'abnormal flag' ),  its use extends to other use cases where coded interpretations  are relevant.  Often reported as one or more simple compact codes this element is often placed adjacent to the result value in reports and flow sheets to signal the meaning/normalcy status of the result." ] ;
       fhir:requirements [ fhir:v "For some results, particularly numeric results, an interpretation is necessary to fully understand the significance of a result." ] ;
       fhir:alias ( [ fhir:v "Abnormal Flag" ] ) ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
