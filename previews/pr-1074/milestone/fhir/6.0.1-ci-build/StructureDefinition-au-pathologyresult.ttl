       fhir:id [ fhir:v "Observation.component.referenceRange" ] ;
       fhir:path [ fhir:v "Observation.component.referenceRange" ] ;
       fhir:short [ fhir:v "Provides guide for interpretation of component result" ] ;
       fhir:definition [ fhir:v "Guidance on how to interpret the value by comparison to a normal or recommended range." ] ;
       fhir:comment [ fhir:v "Most observations only have one generic reference range. Systems MAY choose to restrict to only supplying the relevant reference range based on knowledge about the patient (e.g., specific to the patient's age, gender, weight and other factors), but this might not be possible or appropriate. Whenever more than one reference range is supplied, the differences between them SHOULD be provided in the reference range and/or age properties." ] ;
       fhir:requirements [ fhir:v "Knowing what values are considered \"normal\" can help evaluate the significance of a particular result. Need to be able to provide multiple reference ranges for different contexts." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:base [
         fhir:path [ fhir:v "Observation.component.referenceRange" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "*" ]
       ] ;
       fhir:contentReference [ fhir:v "http://hl7.org/fhir/StructureDefinition/Observation#Observation.referenceRange"^^xsd:anyURI ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "ele-1" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "All FHIR elements must have a @value or children" ] ;
         fhir:expression [ fhir:v "hasValue() or (children().count() > id.count())" ] ;
         fhir:xpath [ fhir:v "@value|f:*|h:div" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Element"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Element>
         ]
       ] ) ;
       fhir:isModifier [ fhir:v false ] ;
       fhir:isSummary [ fhir:v false ] ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "v2" ] ;
         fhir:map [ fhir:v "OBX.7" ]
       ] [
         fhir:identity [ fhir:v "rim" ] ;
         fhir:map [ fhir:v "outboundRelationship[typeCode=REFV]/target[classCode=OBS, moodCode=EVN]" ]
       ] )
     ] )
  ] ; # 
  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Observation" ] ;
       fhir:path [ fhir:v "Observation" ] ;
       fhir:short [ fhir:v "A pathology test result in an Australian healthcare context" ] ;
       fhir:definition [ fhir:v "A pathology test result for a patient. This observation may be a simple test or a panel/study." ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "inv-obs-0" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "A pathology result shall at least have value or data absent reason or a child observation with a value or data absent reason" ] ;
         fhir:expression [ fhir:v "value.exists() or dataAbsentReason.exists() or hasMember.exists() or component.value.exists() or component.dataAbsentReason.exists()" ]
       ] )
     ] [
       fhir:id [ fhir:v "Observation.category" ] ;
       fhir:path [ fhir:v "Observation.category" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "coding.system" ]
         ] [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "coding.code" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ] ;
       fhir:short [ fhir:v "Classification of the service requested as laboratory + more specific discipline where available" ] ;
       fhir:comment [ fhir:v "A fixed category denoting a laboratory service identifies the type of observation and supports handling and searching of observations. A second category to provide a finer grain of discipline, e.g. Haematology should be provided if possible." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Observation.category:lab" ] ;
       fhir:path [ fhir:v "Observation.category" ] ;
       fhir:sliceName [ fhir:v "lab" ] ;
       fhir:short [ fhir:v "Observation generated by laboratories" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Observation.category:lab.coding" ] ;
       fhir:path [ fhir:v "Observation.category.coding" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Observation.category:lab.coding.system" ] ;
