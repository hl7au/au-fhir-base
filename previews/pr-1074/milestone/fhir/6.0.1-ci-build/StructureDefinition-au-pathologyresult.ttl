       fhir:definition [ fhir:v "Describes what was observed. Sometimes this is called the observation \"code\"." ] ;
       fhir:comment [ fhir:v "*All* code-value and  component.code-component.value pairs need to be taken into account to correctly understand the meaning of the observation." ] ;
       fhir:requirements [ fhir:v "Knowing what kind of observation is being made is essential to understanding the observation." ] ;
