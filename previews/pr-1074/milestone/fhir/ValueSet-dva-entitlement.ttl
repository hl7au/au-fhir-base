<http://hl7.org.au/fhir/ValueSet/dva-entitlement> a fhir:ValueSet ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "dva-entitlement"] ; # 
  fhir:meta [
