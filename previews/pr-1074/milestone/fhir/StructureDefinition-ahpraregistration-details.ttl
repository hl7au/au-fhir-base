         fhir:value [
           a fhir:markdown ;
           fhir:v "This extesion is deprecated in AU Base as no continued use or intent for further maturity development has been indicated by the community. Representing a simple Ahpra registration qualification is supported in AU Base Practitioner as `Practitioner.qualification` with the code AHPRA."
         ]
       ] )
     ]
  ] ) ; # 
  fhir:url [ fhir:v "http://hl7.org.au/fhir/StructureDefinition/ahpraregistration-details"^^xsd:anyURI] ; # 
