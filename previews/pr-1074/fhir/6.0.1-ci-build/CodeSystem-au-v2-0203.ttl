  fhir:concept ( [
     fhir:code [ fhir:v "ABN" ] ;
     fhir:display [ fhir:v "Australian Business Number" ] ;
     fhir:definition [ fhir:v "An identifier issued by the Australian Securities and Investments Commission (ASIC) to an entity registered in the Australian Business Register." ]
  ] [
     fhir:code [ fhir:v "ACN" ] ;
     fhir:display [ fhir:v "Australian Company Number" ] ;
     fhir:definition [ fhir:v "An identifier issued by the Australian Securities and Investments Commission (ASIC) when a body becomes registered as a company under Corporations Law." ]
  ] [
     fhir:code [ fhir:v "AHPRA" ] ;
     fhir:display [ fhir:v "Australian Health Practitioner Regulation Agency Registration Number" ] ;
     fhir:definition [ fhir:v "An Australian Health Practitioner Regulation Authority (Ahpra) registration number assigned to a practitioner for each profession in which they are registered. Practitioners registered in more than one profession have one registration number for each profession." ]
  ] [
     fhir:code [ fhir:v "ARBN" ] ;
     fhir:display [ fhir:v "Australian Registered Body Number" ] ;
     fhir:definition [ fhir:v "An identifier issued by the Australian Securities and Investments Commission (ASIC) to a registerable Australian body or foreign company." ]
  ] [
     fhir:code [ fhir:v "CAEI" ] ;
     fhir:display [ fhir:v "Care Agency Employee Identifier" ] ;
     fhir:definition [ fhir:v "A My Health Record assigned Care Agency Employee Identifier is issued to an employee of, or person under contracted arrangement with, a Care Agency that participates in the My Health Record." ]
  ] [
     fhir:code [ fhir:v "CSPRN" ] ;
     fhir:display [ fhir:v "Contracted Service Provider Registration Number" ] ;
     fhir:definition [ fhir:v "A Contracted Service Provider (CSP) Registration Number is issued to organisations that participate in the My Health Record and/or the Healthcare Identifiers Service as a CSP." ]
  ] [
     fhir:code [ fhir:v "DPID" ] ;
     fhir:display [ fhir:v "Australia Post Delivery Point Identifier" ] ;
     fhir:definition [ fhir:v "An Australia Post Delivery Point Identifier (DPID) allocated to an address. A DPID enables each delivery point in Australia to be uniquely identified." ]
  ] [
     fhir:code [ fhir:v "DVAU" ] ;
     fhir:display [ fhir:v "DVA Number" ] ;
     fhir:definition [ fhir:v "An individual's state-based Department of Veterans’ Affairs (DVA) File number. Entitlement is not specified with the use of this code." ]
  ] [
     fhir:code [ fhir:v "DVG" ] ;
     fhir:display [ fhir:v "DVA Number (Gold Card)" ] ;
     fhir:definition [ fhir:v "An individual's state-based Department of Veterans’ Affairs (DVA) File number as displayed on a Veteran Gold Card (the new name for a DVA Gold card). A Veteran Gold Card issued by Department of Veterans’ Affairs (DVA) to an eligible individual provides access to benefits associated with that card." ]
  ] [
     fhir:code [ fhir:v "DVL" ] ;
     fhir:display [ fhir:v "DVA Number (Lilac Card)" ] ;
     fhir:definition [ fhir:v "An individual's state-based Department of Veterans’ Affairs (DVA) File number as displayed on a DVA Lilac card). DVA Lilac Cards are no longer in use and were issued by Department of Veterans’ Affairs (DVA) to eligible individuals 1987-1996." ]
  ] [
     fhir:code [ fhir:v "DVO" ] ;
     fhir:display [ fhir:v "DVA Number (Orange Card)" ] ;
     fhir:definition [ fhir:v "An individual's state-based Department of Veterans’ Affairs (DVA) File number as displayed on a Veteran Orange Card (the new name for a DVA Orange card). A Veteran Orange Card issued by Department of Veterans’ Affairs (DVA) to an eligible individual provides access to benefits associated with that card." ]
  ] [
     fhir:code [ fhir:v "DVW" ] ;
     fhir:display [ fhir:v "DVA Number (White Card)" ] ;
     fhir:definition [ fhir:v "An individual's state-based Department of Veterans’ Affairs (DVA) File number as displayed on a Veteran White Card (the new name for a DVA White card). A Veteran White Card issued by Department of Veterans’ Affairs (DVA) to an eligible individual provides access to benefits associated with that card." ]
  ] [
     fhir:code [ fhir:v "ETP" ] ;
     fhir:display [ fhir:v "Electronic Transfer of Prescription Identifier" ] ;
     fhir:definition [ fhir:v "An identifier allocated by an Electronic Transfer of Prescription (ETP) supplier, sometimes related to a barcode." ]
  ] [
     fhir:code [ fhir:v "GNAF" ] ;
     fhir:display [ fhir:v "Geocoded National Address File Identifier" ] ;
     fhir:definition [ fhir:v "A Geocoded National Address File (G-NAF) Identifier assigned to a location address in the G-NAF. The PSMA G-NAF is Australia’s authoritative, geocoded address file." ]
  ] [
     fhir:code [ fhir:v "HAE" ] ;
     fhir:display [ fhir:v "Health Administration Entity" ] ;
     fhir:definition [ fhir:v "An identifier assigned by the Australian Healthcare Identifiers Service to a health administration entity: a Health Administration Entity number (HAE)." ]
  ] [
     fhir:code [ fhir:v "HSPO" ] ;
     fhir:display [ fhir:v "Healthcare Support Service Provider - Organisation" ] ;
     fhir:definition [ fhir:v "An identifier assigned by the Australian Healthcare Identifiers Service to a healthcare support service provider organisation:  a Healthcare Support Service Provider - Organisation identifier (HSP-O)." ]
  ] [
     fhir:code [ fhir:v "LDI" ] ;
     fhir:display [ fhir:v "Local Dispense Identifier" ] ;
     fhir:definition [ fhir:v "An identifier unique to a dispense within the local system set of dispense records." ]
  ] [
     fhir:code [ fhir:v "LPN" ] ;
     fhir:display [ fhir:v "Local Prescription Number" ] ;
     fhir:definition [ fhir:v "An identifier unique to a prescription within the local system set of prescriptions." ]
  ] [
     fhir:code [ fhir:v "LRI" ] ;
     fhir:display [ fhir:v "Local Report Identifier" ] ;
     fhir:definition [ fhir:v "An identifier unique to a report within the local system set of reports." ]
  ] [
     fhir:code [ fhir:v "LSPN" ] ;
     fhir:display [ fhir:v "Location Specific Practice Number" ] ;
     fhir:definition [ fhir:v "An identifier assigned under the Medicare program to uniquely identify practice sites that provide diagnostic imaging and radiation oncology services." ]
  ] [
     fhir:code [ fhir:v "NATAA" ] ;
     fhir:display [ fhir:v "NATA Accreditation Number" ] ;
     fhir:definition [ fhir:v "A National Association of Testing Authorities (NATA) accreditation number associated with an accredited facility. A NATA accreditation number is associated with an organisation." ]
  ] [
     fhir:code [ fhir:v "NATAS" ] ;
     fhir:display [ fhir:v "NATA Site Number" ] ;
     fhir:definition [ fhir:v "A National Association of Testing Authorities (NATA) site number associated with an accredited facility. A NATA site number represents a specific location associated with an accredited facility, i.e. an organisation with a NATA accreditation number." ]
  ] [
     fhir:code [ fhir:v "NDI" ] ;
     fhir:display [ fhir:v "National Device Identifier" ] ;
     fhir:definition [ fhir:v "An identifier unique to a device assigned by an identifier scheme managed at a national level, this is commonly a My Health Record Assigned Identity - Device (PAI-D) identifier." ]
  ] [
     fhir:code [ fhir:v "NOI" ] ;
     fhir:display [ fhir:v "National Organisation Identifier" ] ;
     fhir:definition [ fhir:v "An identifier assigned by the Australian Healthcare Identifiers Service to a healthcare provider organisation: a Healthcare Provider Identifier - Organisation (HPI-O)." ]
  ] [
     fhir:code [ fhir:v "NPIO" ] ;
     fhir:display [ fhir:v "National provider at organisation identifier" ] ;
     fhir:definition [ fhir:v "A National Provider Identifier at Organisation (NPIO) uniquely identifies an individual practitioner at an organisation using the practitioner’s HPI-I and organisation’s HPI-O to form the NPIO." ]
  ] [
     fhir:code [ fhir:v "NRI" ] ;
     fhir:display [ fhir:v "National Repository Identifier" ] ;
     fhir:definition [ fhir:v "An identifier unique to a repository assigned by an identifier scheme managed at a national level, this is commonly a My Health Record Assigned Identity - Repository (PAI-R) identifier." ]
  ] [
     fhir:code [ fhir:v "PAN" ] ;
     fhir:display [ fhir:v "Pharmacy Approval Number" ] ;
     fhir:definition [ fhir:v "An identifier unique to a pharmacy that is approved to supply pharmaceutical benefits at particular premises under the the National Health Act 1953." ]
  ] [
     fhir:code [ fhir:v "PAIO" ] ;
     fhir:display [ fhir:v "My Health Record (PCEHR) Assigned Identity for Organisations" ] ;
     fhir:definition [ fhir:v "An identifier assigned by the Australian Healthcare Identifiers Service to an organisation to support their participation in the My Health Record system. These organisations are not eligible for another type of Australian Healthcare Identifiers Service identifier (e.g. a HPI-O). For example, the My Health Record System Operator, and the My Health Record National Consumer Portal." ]
  ] [
     fhir:code [ fhir:v "PRES" ] ;
     fhir:display [ fhir:v "Prescriber Number" ] ;
     fhir:definition [ fhir:v "A Pharmaceutical Benefits Scheme (PBS) prescriber identifier assigned to an individual that identifies the right to act as a prescriber under that scheme." ]
  ] [
     fhir:code [ fhir:v "RACSI" ] ;
     fhir:display [ fhir:v "Residential Aged Care Service Identifier" ] ;
     fhir:definition [ fhir:v "A residential aged care service identifier, commonly known as RACS ID or RACF ID, assigned by the Department of Health to a residential aged care service subsidised by the Australian Government. An organisation may provide more than one residential aged care service." ]
  ] [
     fhir:code [ fhir:v "SEN" ] ;
     fhir:display [ fhir:v "Commonwealth Seniors Health Card" ] ;
     fhir:definition [ fhir:v "An identifier unique to an individual, used to confirm concessions by most government agencies and utility providers, as displayed on a Commonwealth Seniors Healthcare Card. A Commonwealth Seniors Healthcare Card may be issued by Services Australia or Department of Veterans’ Affairs (DVA) to an eligible individual to provide access to certain benefits." ]
  ] [
     fhir:code [ fhir:v "UPIN" ] ;
     fhir:display [ fhir:v "Medicare Provider Number" ] ;
     fhir:definition [ fhir:v "A Medicare provider number, assigned by Services Australia under the Medicare program, to practitioners who provide services that are eligible for a Medicare benefit. This is a location-specific identifier, a practitioner may hold more than one." ]
  ] [
     fhir:code [ fhir:v "VDI" ] ;
     fhir:display [ fhir:v "Vendor Directory Identifier" ] ;
     fhir:definition [ fhir:v "A unique vendor identifier allocated to a provider directory entry (PractitionerRole or HealthcareService)." ]
  ] ) . # 

# -------------------------------------------------------------------------------------

