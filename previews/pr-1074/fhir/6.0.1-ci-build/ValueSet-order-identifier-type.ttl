     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet order-identifier-type</b></p><a name=\"order-identifier-type\"> </a><a name=\"hcorder-identifier-type\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profile: <code>https://healthterminologies.gov.au/fhir/StructureDefinition/composed-value-set-4</code></p></div><ul><li>Include these codes as defined in <a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v2-0203.html\"><code>http://terminology.hl7.org/CodeSystem/v2-0203</code></a><span title=\"Version is explicitly stated to be 5.0.0\"> version ?5.0.0</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v2-0203.html#v2-0203-FGN\">FGN</a></td><td style=\"color: #cccccc\">Filler Group Number</td><td>Unique identifier assigned to a group of orders by the filler application.</td></tr><tr><td><a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v2-0203.html#v2-0203-FILL\">FILL</a></td><td style=\"color: #cccccc\">Filler Identifier</td><td>An identifier for a request where the identifier is issued by the person, or service, that produces the observations or fulfills the request.</td></tr><tr><td><a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v2-0203.html#v2-0203-PGN\">PGN</a></td><td style=\"color: #cccccc\">Placer Group Number</td><td>Unique identifier assigned to a group of orders by the placer application.</td></tr><tr><td><a href=\"http://terminology.hl7.org/7.2.0/CodeSystem-v2-0203.html#v2-0203-PLAC\">PLAC</a></td><td style=\"color: #cccccc\">Placer Identifier</td><td>An identifier for a request where the identifier is issued by the person or service making the request.</td></tr></table></li></ul></div>"^^rdf:XMLLiteral ]
