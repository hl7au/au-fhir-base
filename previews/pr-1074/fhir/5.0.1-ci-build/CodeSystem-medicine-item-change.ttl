  fhir:compositional [ fhir:v false] ; # 
  fhir:versionNeeded [ fhir:v false] ; # 
  fhir:content [ fhir:v "complete"] ; # 
  fhir:count [ fhir:v "15"^^xsd:nonNegativeInteger] ; # 
  fhir:concept ( [
     fhir:code [ fhir:v "nochange" ] ;
     fhir:display [ fhir:v "Unchanged" ] ;
     fhir:definition [ fhir:v "No change has been made to this medicine." ]
  ] [
     fhir:code [ fhir:v "changed" ] ;
     fhir:display [ fhir:v "Change occurred" ] ;
     fhir:definition [ fhir:v "A change has been made to this medicine; for example, new medicine prescribed or dosage change." ] ;
     fhir:concept ( [
       fhir:code [ fhir:v "new" ] ;
       fhir:display [ fhir:v "New" ] ;
       fhir:definition [ fhir:v "A new medicine item is introduced." ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "prescribed" ] ;
         fhir:display [ fhir:v "New prescription" ] ;
         fhir:definition [ fhir:v "A new medicine item has been prescribed." ]
       ] )
     ] [
       fhir:code [ fhir:v "ceased" ] ;
       fhir:display [ fhir:v "Ceased" ] ;
       fhir:definition [ fhir:v "A medicine that was previously taken by the individual may actually be ceased as it required immediate attention. This cessation is anticipated to be permanent. Example uses: the medicine in question is considered ineffective or has caused serious adverse effects." ]
     ] [
       fhir:code [ fhir:v "suspended" ] ;
       fhir:display [ fhir:v "Suspended" ] ;
       fhir:definition [ fhir:v "A medicine that was previously taken by the individual may be temporarily stopped. Example uses: medication in question may reach toxicity blood level, or suspected to have caused some undesirable effects; or needs to be suspended before a surgical/diagnostic procedure." ]
     ] [
       fhir:code [ fhir:v "cancelled" ] ;
       fhir:display [ fhir:v "Cancelled" ] ;
       fhir:definition [ fhir:v "The prescription for this medicine item was cancelled. The patient may be advised to complete the course of the prescribed medicine. This advice is a clinical decision made based on assessment of the patients clinical condition." ]
     ] [
       fhir:code [ fhir:v "amended" ] ;
       fhir:display [ fhir:v "Amended" ] ;
       fhir:definition [ fhir:v "The current medicine item has been changed in some way, e.g. dose, form, route, frequency change." ]
     ] )
  ] [
     fhir:code [ fhir:v "recommended" ] ;
     fhir:display [ fhir:v "Change was recommended" ] ;
     fhir:definition [ fhir:v "A change has been recommended to this medicine but may not have occurred yet, e.g. medicine recommended to be stopped." ] ;
     fhir:concept ( [
       fhir:code [ fhir:v "new-recommended" ] ;
       fhir:display [ fhir:v "New recommended medicine" ] ;
       fhir:definition [ fhir:v "A new medicine item is recommended." ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "prescription-recommended" ] ;
         fhir:display [ fhir:v "Prescription recommended" ] ;
         fhir:definition [ fhir:v "It may be recommended that the usual GP prescribe a new medicine to be taken by the individual. The addition may not be urgent or there may be an arrangement that all medicine changes are to be enacted by the GP as the coordinator of the individual‘s overall care." ]
       ] )
     ] [
       fhir:code [ fhir:v "review-recommended" ] ;
       fhir:display [ fhir:v "Review recommended" ] ;
       fhir:definition [ fhir:v "It may be recommended to the usual GP that a medicine that was previously taken by the individual be reviewed. The outcome of the review may be that the medicine is amended or stopped." ]
     ] [
       fhir:code [ fhir:v "cessation-recommended" ] ;
       fhir:display [ fhir:v "Cessation recommended" ] ;
       fhir:definition [ fhir:v "It may be recommended to the usual GP that a medicine that was previously taken by the individual be ceased." ]
     ] [
       fhir:code [ fhir:v "suspension-recommended" ] ;
       fhir:display [ fhir:v "Suspension recommended" ] ;
       fhir:definition [ fhir:v "It may be recommended to the usual GP that a medicine item that was previously taken by the individual be temporarily stopped. Example uses: medication in question may reach toxicity blood level, or suspected to have caused some undesirable effects; or needs to be suspended before a surgical/diagnostic procedure." ]
     ] [
       fhir:code [ fhir:v "cancellation-recommended" ] ;
       fhir:display [ fhir:v "Cancellation recommended" ] ;
       fhir:definition [ fhir:v "The prescription for this medicine item is recommended to be cancelled. The patient may be advised to complete the course of the prescribed medicine. This advice is a clinical decision made based on assessment of the patients clinical condition." ]
     ] )
  ] ) . # 

